    <EmbeddedResource Include="Resources\notepad_window.png" />
    <EmbeddedResource Include="Resources\notepad_window_black.png" />
    <EmbeddedResource Include="Resources\notepad_clear.png" />
    <EmbeddedResource Include="Resources\notepad_clear_hover.png" />
  </ItemGroup>
  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <MakeDir Directories="$(AmongUsDir)\BepInEx\plugins\" />
    <Copy
      SourceFiles="$(OutputPath)$(AssemblyName).dll"
      DestinationFolder="$(AmongUsDir)\BepInEx\plugins\"
      SkipUnchangedFiles="false" />
    <Message Text="DLL kopierad till plugins!" Importance="high" />
  </Target>
